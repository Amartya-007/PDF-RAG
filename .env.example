RAG_DATA_DIR=backend/data
# Use :memory: only for constrained tests; file-backed SQLite is the normal mode.
RAG_SQLITE_PATH=backend/data/metadata.sqlite3
OLLAMA_BASE_URL=http://localhost:11434

RAG_GENERATION_MODEL=qwen3.5:9b
RAG_DEVELOPMENT_MODEL=qwen3.5:4b
RAG_ACTIVE_MODEL=qwen3.5:4b

RAG_GENERATION_CONTEXT=16384
RAG_DEVELOPMENT_CONTEXT=8192

RAG_SPARSE_TOP_K=40
RAG_FINAL_CONTEXT_CHUNKS=8

RAG_TEMPERATURE=0.1

RAG_USE_OLLAMA=1
